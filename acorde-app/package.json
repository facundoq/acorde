{
  "name": "acorde-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "build:apk": "bash ../build-apk.sh",
    "build:web": "npx expo export --platform web",
    "build:android": "npx eas-cli build -p android --profile production --local --non-interactive",
    "build:prod": "npm run build:web && npm run build:android"
  },
  "dependencies": {
    "@react-navigation/material-top-tabs": "^7.4.18",
    "@react-navigation/native": "^7.1.28",
    "acorde-core": "file:../acorde-core",
    "cheerio": "1.0.0-rc.12",
    "expo": "~55.0.6",
    "expo-audio": "~0.2.0",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-blob-util": "^0.24.7",
    "react-native-fetch-api": "^3.0.0",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
